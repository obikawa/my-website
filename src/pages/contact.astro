---
import Layout from '../layouts/Layout.astro';
---

<Layout title="お問い合わせ" description="社会保険労務士事務所へのお問い合わせページです。お気軽にご連絡ください。">

  <section class="bg-gradient-to-br from-primary-800 to-primary-600 text-white py-16 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <p class="text-primary-200 text-sm font-medium tracking-widest uppercase mb-3">Contact</p>
      <h1 class="text-4xl font-bold">お問い合わせ</h1>
      <p class="mt-4 text-primary-100 max-w-xl mx-auto">
        ご質問・ご相談はこちらのフォームからお気軽にどうぞ。<br />
        通常2〜3営業日以内にご返信いたします。
      </p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-2xl mx-auto">

      <!-- Info cards -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-12">
        <div class="text-center bg-gray-50 rounded-xl p-5">
          <div class="w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <p class="text-xs font-semibold text-gray-600">返信目安</p>
          <p class="text-sm text-gray-800 font-medium mt-1">2〜3営業日</p>
        </div>
        <div class="text-center bg-gray-50 rounded-xl p-5">
          <div class="w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <p class="text-xs font-semibold text-gray-600">初回相談</p>
          <p class="text-sm text-gray-800 font-medium mt-1">無料</p>
        </div>
        <div class="text-center bg-gray-50 rounded-xl p-5">
          <div class="w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.868V15.13a1 1 0 01-1.447.9L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z" />
            </svg>
          </div>
          <p class="text-xs font-semibold text-gray-600">オンライン</p>
          <p class="text-sm text-gray-800 font-medium mt-1">全国対応</p>
        </div>
      </div>

      <!-- Form -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 sm:p-10">
        <h2 class="text-xl font-bold text-gray-900 mb-6">お問い合わせフォーム</h2>

        <!-- Netlify Form -->
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/contact/success"
          class="space-y-6"
        >
          <!-- Netlify hidden fields -->
          <input type="hidden" name="form-name" value="contact" />
          <div class="hidden">
            <label>
              このフィールドには入力しないでください：
              <input name="bot-field" />
            </label>
          </div>

          <!-- Name -->
          <div>
            <label for="name" class="block text-sm font-semibold text-gray-700 mb-2">
              お名前 <span class="text-red-500 ml-1">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="山田 太郎"
              class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-shadow"
            />
          </div>

          <!-- Furigana -->
          <div>
            <label for="furigana" class="block text-sm font-semibold text-gray-700 mb-2">
              ふりがな <span class="text-red-500 ml-1">*</span>
            </label>
            <input
              type="text"
              id="furigana"
              name="furigana"
              required
              placeholder="やまだ たろう"
              class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-shadow"
            />
          </div>

          <!-- Company -->
          <div>
            <label for="company" class="block text-sm font-semibold text-gray-700 mb-2">
              会社名 <span class="text-red-500 ml-1">*</span>
            </label>
            <input
              type="text"
              id="company"
              name="company"
              required
              placeholder="株式会社〇〇"
              class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-shadow"
            />
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">
              メールアドレス <span class="text-red-500 ml-1">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="example@company.com"
              class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-shadow"
            />
          </div>

          <!-- Phone -->
          <div>
            <label for="phone" class="block text-sm font-semibold text-gray-700 mb-2">
              電話番号
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              placeholder="090-0000-0000（任意）"
              class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-shadow"
            />
          </div>

          <!-- Category -->
          <div>
            <label for="category" class="block text-sm font-semibold text-gray-700 mb-2">
              相談種別 <span class="text-red-500 ml-1">*</span>
            </label>
            <select
              id="category"
              name="category"
              required
              class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-gray-800 bg-white focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-shadow"
            >
              <option value="" disabled selected>選択してください</option>
              <option value="AI社会実装の相談">AI社会実装の相談（小さな専門家づくり）</option>
              <option value="セミナー・講演の依頼">セミナー・講演の依頼</option>
              <option value="顧問契約の相談">顧問契約の相談</option>
              <option value="男性育休・両立支援">男性育休・両立支援の相談</option>
              <option value="就業規則・働き方改革">就業規則・働き方改革の相談</option>
              <option value="その他">その他</option>
            </select>
          </div>

          <!-- Message -->
          <div>
            <label for="message" class="block text-sm font-semibold text-gray-700 mb-2">
              お問い合わせ内容 <span class="text-red-500 ml-1">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              placeholder="ご相談内容をできるだけ具体的にお書きください。"
              class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-shadow resize-none"
            ></textarea>
          </div>

          <!-- Privacy -->
          <div class="flex items-start gap-3">
            <input
              type="checkbox"
              id="privacy"
              name="privacy"
              required
              class="mt-1 w-4 h-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500"
            />
            <label for="privacy" class="text-sm text-gray-600 leading-relaxed">
              <a href="#" class="text-primary-700 underline hover:no-underline">プライバシーポリシー</a>に同意の上、送信します。<span class="text-red-500 ml-1">*</span>
            </label>
          </div>

          <button
            type="submit"
            class="w-full bg-primary-700 text-white font-bold py-4 px-6 rounded-lg hover:bg-primary-800 transition-colors text-base"
          >
            送信する
          </button>
        </form>
      </div>

      <!-- Office address note -->
      <div class="mt-8 text-center text-sm text-gray-500">
        <p>〒460-0008 愛知県名古屋市中区栄5-26-39 GS栄ビル3F</p>
        <p class="mt-1">営業時間：平日 9:00〜18:00（要予約）</p>
      </div>

    </div>
  </section>
</Layout>
