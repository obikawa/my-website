function getShihoMonthly(salary){
  for(const[lo,hi,sh]of SHIHO_TABLE){if(salary>=lo&&salary<hi)return sh;}
  return 650000;
}

/* ===== 住民税概算 ===== */
function estimateJuminzei(monthlySalary, dependents){
  const annual=monthlySalary*12;
  let ded;
  if(annual<=1625000)ded=550000;
  else if(annual<=1800000)ded=annual*0.4-100000;
  else if(annual<=3600000)ded=annual*0.3+80000;
  else if(annual<=6600000)ded=annual*0.2+440000;
  else if(annual<=8500000)ded=annual*0.1+1100000;
  else ded=1950000;
  const income=annual-ded;
  const socialDed=annual*0.15;
  const fuyoDed = dependents >= 1 ? 330000 + (dependents - 1) * 380000 : 0;
  const taxable=Math.max(0, income - 430000 - socialDed - fuyoDed);
  const annualTax=Math.round(taxable*0.1)+5000;
  return Math.max(0, Math.round(annualTax/12));
}

/* ===== 自動計算 & フィールド連動 ===== */
let shihoManual=false, juminManual=false;

function autoCalcFromSalary(){
  const salary=+$('baseSalary').value||0;
  const dep=+$('dependents').value;
  const hr=+$('healthRate').value||0;
  const shiho=getShihoMonthly(salary);
  const healthIns=Math.round(shiho*hr/100);
  const pensionIns=Math.round(shiho*0.0915);
  const jumin=estimateJuminzei(salary, dep);
  $('autoShiho').textContent=fmtY(shiho);
  $('autoHealth').textContent=fmtY(healthIns);
  $('autoPension').textContent=fmtY(pensionIns);
  $('autoJumin').textContent=fmtY(jumin)+' /月';
  if(!shihoManual){$('shihoMonthly').value=shiho;$('shihoAutoLabel').textContent='自動';$('shihoAutoLabel').style.color='var(--ws-primary)';}
  else{$('shihoAutoLabel').textContent='手動';$('shihoAutoLabel').style.color='var(--ws-accent)';}
  if(!juminManual){$('zyuminTax').value=jumin;$('juminAutoLabel').textContent='自動';$('juminAutoLabel').style.color='var(--ws-primary)';}
  else{$('juminAutoLabel').textContent='手動';$('juminAutoLabel').style.color='var(--ws-accent)';}
}

$('shihoMonthly').addEventListener('input',()=>{shihoManual=true;autoCalcFromSalary();updateAll();});
$('zyuminTax').addEventListener('input',()=>{juminManual=true;autoCalcFromSalary();updateAll();});
$('baseSalary').addEventListener('input',()=>{shihoManual=false;juminManual=false;autoCalcFromSalary();renderHolCalendars();updateAll();});
$('dependents').addEventListener('change',()=>{if(!juminManual){autoCalcFromSalary();}updateAll();});

/* ===== 休日管理 ===== */
let customDayOff=new Set(), customDayOn=new Set();

function getSatMode(){return document.querySelector('input[name="sat"]:checked').value;}
function isHolidayOff(){return $('holidayOff').checked;}

function isDefaultOff(y,m,d){
  const dt=new Date(y,m-1,d);
  const dow=dt.getDay();
  if(dow===0) return true;
  if(dow===6){
    const sm=getSatMode();
    if(sm==='all_off') return true;
    if(sm==='all_on') return false;
    const weekNum=Math.ceil(d/7);
    return weekNum%2===1;
  }
  if(isHolidayOff()&&isNationalHoliday(y,m,d)) return true;
  return false;
}

function isDayOff(y,m,d){
  const key=`${y}-${String(m).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
  if(customDayOn.has(key)) return false;
  if(customDayOff.has(key)) return true;
  return isDefaultOff(y,m,d);
}

function toggleDayOff(y,m,d){
  const key=`${y}-${String(m).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
  const defOff=isDefaultOff(y,m,d);
  if(defOff){
    if(customDayOn.has(key)){customDayOn.delete(key);}
    else{customDayOn.add(key);customDayOff.delete(key);}
  }else{
    if(customDayOff.has(key)){customDayOff.delete(key);}
    else{customDayOff.add(key);customDayOn.delete(key);}
  }
}

/* 賃金計算期間 */
function getPayPeriod(calMonth,cutoff){
  const y=calMonth.getFullYear(),m=calMonth.getMonth();
  if(cutoff>=28) return{start:new Date(y,m,1),end:new Date(y,m+1,0)};
  const pm=m===0?11:m-1,py=m===0?y-1:y;
  return{start:new Date(py,pm,cutoff+1),end:new Date(y,m,cutoff)};
}

function countWorkDaysInPeriod(pp){
  let c=0;const d=new Date(pp.start);
  while(d<=pp.end){if(!isDayOff(d.getFullYear(),d.getMonth()+1,d.getDate()))c++;d.setDate(d.getDate()+1);}
  return c;
}

/* ===== 休日カレンダー描画 ===== */
function renderHolCalendars(){
  const m1=currentMonth1,m2=getMonth2();
  let html='';
  [m1,m2].forEach(mo=>{
    const y=mo.getFullYear(),m=mo.getMonth(),dim=eom(y,m+1);
    const fd=new Date(y,m,1).getDay();
    html+=`<div class="hol-cal"><div class="hc-header">${y}年${m+1}月</div><table><thead><tr><th class="sun">日</th><th>月</th><th>火</th><th>水</th><th>木</th><th>金</th><th class="sat">土</th></tr></thead><tbody>`;
    let dn=1;
    for(let w=0;w<6;w++){
      html+='<tr>';
      for(let d=0;d<7;d++){
        if(w===0&&d<fd){html+='<td class="empty"></td>';}
        else if(dn>dim){html+='<td class="empty"></td>';}
        else{
          const off=isDayOff(y,m+1,dn);
          const hol=isNationalHoliday(y,m+1,dn);
          const dow=new Date(y,m,dn).getDay();
          let cls='hd';
          if(off)cls+=' off';
          if(hol)cls+=' holiday-mark';
          else if(dow===0)cls+=' sun-day';
          else if(dow===6)cls+=' sat-day';
          const title=hol?getHolidayName(y,m+1,dn):'';
          html+=`<td><span class="${cls}" data-y="${y}" data-m="${m+1}" data-d="${dn}" title="${title}">${dn}</span></td>`;
          dn++;
        }
      }
      html+='</tr>';
      if(dn>dim)break;
    }
    html+='</tbody></table></div>';
  });
  $('holCalendars').innerHTML=html;
  document.querySelectorAll('.hol-cal .hd').forEach(el=>{
    el.addEventListener('click',()=>{
      toggleDayOff(+el.dataset.y,+el.dataset.m,+el.dataset.d);
      renderHolCalendars();
      renderCalendars();
      updateAll();
    });
  });
  const cutoff=+$('cutoffDay').value;
  const pp1=getPayPeriod(m1,cutoff),pp2=getPayPeriod(m2,cutoff);
  const wd1=countWorkDaysInPeriod(pp1),wd2=countWorkDaysInPeriod(pp2);
  $('holResult').innerHTML=`${m1.getMonth()+1}月分の所定労働日数: <strong>${wd1}日</strong>　／　${m2.getMonth()+1}月分: <strong>${wd2}日</strong>`;
}

/* ===== 育休選択 状態 ===== */
let currentMonth1=new Date();currentMonth1.setDate(1);
let leaveCount=2;
let period1={1:[],2:[]},period2={1:[],2:[]};
let activePeriod=1,pickState='start',pickStartInfo=null;
function getMonth2(){const m=new Date(currentMonth1);m.setMonth(m.getMonth()+1);return m;}

/* ===== 育休カレンダー ===== */
function renderCalendars(){
  const m1=currentMonth1,m2=getMonth2();
  $('monthLabel').textContent=`${m1.getFullYear()}年${m1.getMonth()+1}月・${m2.getFullYear()}年${m2.getMonth()+1}月`;
  $('cal1Title').textContent=`${m1.getFullYear()}年${m1.getMonth()+1}月`;
  $('cal2Title').textContent=`${m2.getFullYear()}年${m2.getMonth()+1}月`;
  $('cal1Body').innerHTML=buildCalBody(m1,1);
  $('cal2Body').innerHTML=buildCalBody(m2,2);
  document.querySelectorAll('.cal td[data-day]').forEach(td=>td.addEventListener('click',()=>handleCellClick(+td.dataset.cal,+td.dataset.day)));
}

function buildCalBody(dateObj,calIdx){
  const y=dateObj.getFullYear(),m=dateObj.getMonth(),fd=new Date(y,m,1).getDay(),dim=eom(y,m+1);
  const p1=period1[calIdx]||[],p2=period2[calIdx]||[];
  let html='',dn=1;
  for(let w=0;w<6;w++){html+='<tr>';for(let d=0;d<7;d++){if(w===0&&d<fd){html+='<td class="empty"></td>';}else if(dn>dim){html+='<td class="empty"></td>';}else{
    const cls=['day'];
    if(p1.includes(dn))cls.push('sel-1');else if(p2.includes(dn))cls.push('sel-2');
    if(dn===dim)cls.push('eom');
    const off=isDayOff(y,m+1,dn);
    const hol=isNationalHoliday(y,m+1,dn);
    if(off&&!p1.includes(dn)&&!p2.includes(dn))cls.push('off-day');
    if(hol)cls.push('hol-day');
    html+=`<td data-cal="${calIdx}" data-day="${dn}"><span class="${cls.join(' ')}">${dn}</span></td>`;dn++;
  }}html+='</tr>';if(dn>dim)break;}
  return html;
}

function handleCellClick(ci,day){
  const aO=activePeriod===1?period1:period2,oO=activePeriod===1?period2:period1;
  if(pickState==='start'){aO[1]=[];aO[2]=[];pickStartInfo={calIdx:ci,day};aO[ci]=[day];pickState='end';}
  else{
    const s=pickStartInfo,e={calIdx:ci,day};const sa=(s.calIdx-1)*100+s.day,ea=(e.calIdx-1)*100+e.day;
    let ss,ee;if(ea<sa){ss=e;ee=s;}else{ss=s;ee=e;}
    aO[1]=[];aO[2]=[];const dim1=eom(currentMonth1.getFullYear(),currentMonth1.getMonth()+1);
    if(ss.calIdx===1&&ee.calIdx===1){for(let d=ss.day;d<=ee.day;d++)aO[1].push(d);}
    else if(ss.calIdx===2&&ee.calIdx===2){for(let d=ss.day;d<=ee.day;d++)aO[2].push(d);}
    else{for(let d=ss.day;d<=dim1;d++)aO[1].push(d);for(let d=1;d<=ee.day;d++)aO[2].push(d);}
    if(leaveCount===2){aO[1]=aO[1].filter(d=>!oO[1].includes(d));aO[2]=aO[2].filter(d=>!oO[2].includes(d));}
    const tot=period1[1].length+period1[2].length+period2[1].length+period2[2].length;
    if(tot>28){alert('産後パパ育休は最大28日までです。');aO[1]=[];aO[2]=[];}
    pickState='start';pickStartInfo=null;
    if(leaveCount===2&&activePeriod===1&&(aO[1].length+aO[2].length)>0&&!(period2[1].length+period2[2].length))switchPeriod(2);
  }
  renderCalendars();updateAll();
}
function switchPeriod(p){activePeriod=p;pickState='start';pickStartInfo=null;document.querySelectorAll('.period-tab').forEach(t=>t.classList.toggle('active',+t.dataset.period===p));updatePickingLabel();}
function updatePickingLabel(){$('currentPicking').classList.toggle('p2',activePeriod===2);$('pickLabel').textContent=activePeriod===1?'1回目':'2回目';$('pickInstruction').innerHTML=pickState==='start'?'の育休期間の<strong>開始日</strong>をタップ':'の育休期間の<strong>終了日</strong>をタップ';}
function setLeaveCount(n){leaveCount=n;document.querySelectorAll('#countToggle button').forEach(b=>b.classList.toggle('active',+b.dataset.count===n));if(n===1){period2={1:[],2:[]};$('period2Tab').style.display='none';$('p2SummaryItem').style.display='none';switchPeriod(1);}else{$('period2Tab').style.display='';$('p2SummaryItem').style.display='';}renderCalendars();updateAll();}
function clearPeriod(p){if(p===1)period1={1:[],2:[]};else period2={1:[],2:[]};if(activePeriod===p){pickState='start';pickStartInfo=null;}renderCalendars();updateAll();}

/* ===== 計算 ===== */
function getAbsentWorkDaysInPP(pp,m1,m2,p1,p2){
  const ld=new Set();
  [p1,p2].forEach(po=>{[1,2].forEach(ci=>{const ref=ci===1?m1:m2;const y=ref.getFullYear(),m=ref.getMonth();(po[ci]||[]).forEach(d=>{const dt=new Date(y,m,d);if(dt>=pp.start&&dt<=pp.end)ld.add(dt.getTime());});});});
  let c=0;ld.forEach(t=>{const d=new Date(t);if(!isDayOff(d.getFullYear(),d.getMonth()+1,d.getDate()))c++;});return c;
}
function getLeaveDaysInPP(pp,m1,m2,p1,p2){
  const s=new Set();
  [p1,p2].forEach(po=>{[1,2].forEach(ci=>{const ref=ci===1?m1:m2;const y=ref.getFullYear(),m=ref.getMonth();(po[ci]||[]).forEach(d=>{const dt=new Date(y,m,d);if(dt>=pp.start&&dt<=pp.end)s.add(dt.getTime());});});});
  return s.size;
}
function calcMonth(o){
  const na=Math.max(0,o.absentWorkDays-o.workInLeave);
  const ded=o.wd>0?Math.round(o.base/o.wd*na):0;
  const gross=Math.max(0,o.base-ded);
  const hi=o.exempt?0:Math.round(o.shiho*o.hr/100);
  const pi=o.exempt?0:Math.round(o.shiho*.0915);
  const ei=Math.round(gross*.0055);
  const st=hi+pi+ei;const tx=Math.max(0,gross-st);const it=calcTax(tx,o.dep);
  const th=gross-st-it-o.zt;
  let dw=Math.round(o.base/30);const cap=dw>CAP;if(cap)dw=CAP;
  const ik=Math.round(dw*o.bd*.67);const sh=o.sk===1?Math.round(dw*o.bd*.13):0;
  return{base:o.base,ded,gross,hi,pi,ei,st,tx,it,zt:o.zt,th,ik,sh,total:th+ik+sh,exempt:o.exempt,bd:o.bd,cap,dw,wd:o.wd};
}
function judgeEx(days,eomD,wil){if(!days.length)return{ex:false,r:'育休取得なし'};if(days.includes(eomD))return{ex:true,r:'月末日を含む育休'};const e=Math.max(0,days.length-wil);return e>=14?{ex:true,r:'同月内14日以上'}:{ex:false,r:`${e}日（14日未満）`};}

/* ===== 表示更新 ===== */
function fmtDR(days,dt){if(!days.length)return'';const s=[...days].sort((a,b)=>a-b),ml=dt.getMonth()+1;const rr=[];let rs=s[0],re=s[0];for(let i=1;i<s.length;i++){if(s[i]===re+1)re=s[i];else{rr.push([rs,re]);rs=s[i];re=s[i];}}rr.push([rs,re]);return rr.map(([a,b])=>a===b?`${ml}/${a}`:`${ml}/${a}〜${ml}/${b}`).join(', ');}
function fmtP(po){const p=[];if(po[1]&&po[1].length)p.push(fmtDR(po[1],currentMonth1));if(po[2]&&po[2].length)p.push(fmtDR(po[2],getMonth2()));return p.join(' + ');}

function updateAll(){
  const base=+$('baseSalary').value||0,shiho=+$('shihoMonthly').value||0,cutoff=+$('cutoffDay').value;
  const dep=+$('dependents').value,zt=+$('zyuminTax').value||0,hr=+$('healthRate').value||0;
  const wil1=+$('workInLeave1').value||0,wil2=+$('workInLeave2').value||0,sk=+$('shienKyuhu').value;
  const m1=currentMonth1,m2=getMonth2();
  const eom1=eom(m1.getFullYear(),m1.getMonth()+1),eom2=eom(m2.getFullYear(),m2.getMonth()+1);
  const pp1=getPayPeriod(m1,cutoff),pp2=getPayPeriod(m2,cutoff);
  const wd1=countWorkDaysInPeriod(pp1),wd2=countWorkDaysInPeriod(pp2);
  const fpp=pp=>`${pp.start.getMonth()+1}/${pp.start.getDate()}〜${pp.end.getMonth()+1}/${pp.end.getDate()}`;
  $('payPeriodInfo').innerHTML=`<strong>賃金計算期間</strong>（${cutoff>=28?'末日':cutoff+'日'}締め）<br>${m1.getMonth()+1}月分: ${fpp(pp1)}（所定 ${wd1}日）<br>${m2.getMonth()+1}月分: ${fpp(pp2)}（所定 ${wd2}日）`;
  const l1=[...new Set([...(period1[1]||[]),...(period2[1]||[])])].sort((a,b)=>a-b);
  const l2=[...new Set([...(period1[2]||[]),...(period2[2]||[])])].sort((a,b)=>a-b);
  const j1=judgeEx(l1,eom1,wil1),j2=judgeEx(l2,eom2,wil2);
  const ab1=getAbsentWorkDaysInPP(pp1,m1,m2,period1,period2),ab2=getAbsentWorkDaysInPP(pp2,m1,m2,period1,period2);
  const bd1=getLeaveDaysInPP(pp1,m1,m2,period1,period2),bd2=getLeaveDaysInPP(pp2,m1,m2,period1,period2);
  const p1T=period1[1].length+period1[2].length,p2T=period2[1].length+period2[2].length;
  $('p1Count').textContent=`（${p1T}日）`;$('p2Count').textContent=`（${p2T}日）`;
  $('p1Summary').innerHTML=p1T>0?fmtP(period1)+` <span style="color:var(--ws-text-sub);font-size:11px">(${p1T}日)</span>`:'<span style="color:var(--ws-text-sub);font-style:italic">未選択</span>';
  $('p2Summary').innerHTML=p2T>0?fmtP(period2)+` <span style="color:var(--ws-text-sub);font-size:11px">(${p2T}日)</span>`:'<span style="color:var(--ws-text-sub);font-style:italic">未選択</span>';
  const tot=p1T+p2T;$('totalDays').textContent=tot;
  const wE=$('daysWarning');if(tot>28){wE.style.display='block';wE.style.color='var(--ws-danger)';wE.textContent='⚠ 28日超過';}else if(tot===28){wE.style.display='block';wE.style.color='var(--ws-success)';wE.textContent='✓ 最大日数';}else wE.style.display='none';
  $('judgmentBadges').innerHTML=`<div class="${j1.ex?'j-exempt':'j-no'}"><strong>${m1.getMonth()+1}月:</strong> ${j1.ex?'✓ 社保免除':'✗ 免除なし'}<span style="font-size:11px;display:block;opacity:.8">${j1.r}</span></div><div class="${j2.ex?'j-exempt':'j-no'}"><strong>${m2.getMonth()+1}月:</strong> ${j2.ex?'✓ 社保免除':'✗ 免除なし'}<span style="font-size:11px;display:block;opacity:.8">${j2.r}</span></div>`;
  $('month1Label').textContent=`${m1.getMonth()+1}月分（欠勤${ab1}日 / 所定${wd1}日）`;
  $('month2Label').textContent=`${m2.getMonth()+1}月分（欠勤${ab2}日 / 所定${wd2}日）`;
  const cur=calcMonth({base,shiho,wd:wd1,dep,zt,hr,absentWorkDays:0,workInLeave:0,exempt:false,bd:0,sk:0});
  const mo1=calcMonth({base,shiho,wd:wd1,dep,zt,hr,absentWorkDays:ab1,workInLeave:wil1,exempt:j1.ex,bd:Math.max(0,bd1-wil1),sk});
  const mo2=calcMonth({base,shiho,wd:wd2,dep,zt,hr,absentWorkDays:ab2,workInLeave:wil2,exempt:j2.ex,bd:Math.max(0,bd2-wil2),sk});
  renderBD('bdCurrent',cur,false);renderBD('bdMonth1',mo1,true);renderBD('bdMonth2',mo2,true);
  $('amtCurrent').textContent=fmtY(cur.total);$('amtMonth1').textContent=fmtY(mo1.total);$('amtMonth2').textContent=fmtY(mo2.total);
  renderDiff('diffMonth1',mo1.total-cur.total);renderDiff('diffMonth2',mo2.total-cur.total);
  const ic=mo1.cap||mo2.cap;$('capWarning').style.display=ic?'block':'none';
  if(ic){const dr=Math.round(base/30);$('capWarningMsg').innerHTML=`賃金日額 ${dr.toLocaleString()}円 が上限 ${CAP.toLocaleString()}円/日を超えるため、給付金は上限額で計算しています。`;}
  const both=j1.ex&&j2.ex;
  if(both&&tot>0){const d2=(mo1.total+mo2.total)-(cur.total*2);$('highlightBox').style.display='block';$('hlAmount').textContent=(d2>=0?'+':'')+fmtY(d2);$('hlDesc').textContent=`現状2ヶ月 ${fmtY(cur.total*2)} → 育休2ヶ月 ${fmtY(mo1.total+mo2.total)}`;}else $('highlightBox').style.display='none';
  let msg='';if(!tot)msg='育休期間を選ぶとシミュレーションが表示されます。';
  else if(j1.ex&&j2.ex){msg=`<strong>✨ 2ヶ月分の社保免除！</strong> 健保・厚年 計${fmtY((cur.hi+cur.pi)*2)}が免除。給付金と合わせて手取り増。`+(leaveCount===2?'<br><span style="font-size:12px;color:var(--ws-text-sub)">※ 2回分割で別月の月末を含む取得です。</span>':'');}
  else if(j1.ex||j2.ex){const exM=j1.ex?(m1.getMonth()+1):(m2.getMonth()+1);msg=`${exM}月は社保免除。もう1ヶ月分も免除を狙うなら、<strong>2回分割で別月の月末を含む取得</strong>がおすすめです。`;}
  else msg='<strong>社保免除条件未達。</strong>「月末含む」or「同月内14日以上」で免除対象に。';
  $('mainMessage').innerHTML=msg;
  updatePickingLabel();
}
function renderBD(id,d,isL){let h='';h+=`<div class="bk-row"><span>月給</span><span>${fmtY(d.base)}</span></div>`;if(d.ded>0)h+=`<div class="bk-row"><span>欠勤控除（所定${d.wd}日）</span><span>- ${fmtY(d.ded)}</span></div>`;h+=`<div class="bk-row"><span>支給額</span><strong>${fmtY(d.gross)}</strong></div><hr>`;h+=`<div class="bk-row ${d.exempt?'exempt':''}"><span>健康保険</span><span>- ${fmtY(d.hi)}</span></div>`;h+=`<div class="bk-row ${d.exempt?'exempt':''}"><span>厚生年金</span><span>- ${fmtY(d.pi)}</span></div>`;h+=`<div class="bk-row"><span>雇用保険</span><span>- ${fmtY(d.ei)}</span></div>`;h+=`<div class="bk-row"><span>所得税</span><span>- ${fmtY(d.it)}</span></div>`;h+=`<div class="bk-row"><span>住民税</span><span>- ${fmtY(d.zt)}</span></div><hr>`;h+=`<div class="bk-row"><span>給与手取り</span><strong>${fmtY(d.th)}</strong></div>`;if(isL&&d.ik>0)h+=`<div class="bk-row" style="color:var(--ws-primary)"><span>育休給付金${d.cap?' ⚠上限':''}（${d.dw.toLocaleString()}円×${d.bd}日×67%）</span><span>+ ${fmtY(d.ik)}</span></div>`;if(isL&&d.sh>0)h+=`<div class="bk-row" style="color:var(--ws-primary)"><span>出生後休業支援（13%）</span><span>+ ${fmtY(d.sh)}</span></div>`;$(id).innerHTML=h;}
function renderDiff(id,d){const e=$(id);e.textContent=`現状比 ${d>=0?'+':''}${fmtY(d)}`;e.className='comp-diff '+(d>=0?'up':'down');}

/* ===== イベント ===== */
$('prevMonth').addEventListener('click',()=>{currentMonth1.setMonth(currentMonth1.getMonth()-1);renderHolCalendars();renderCalendars();updateAll();});
$('nextMonth').addEventListener('click',()=>{currentMonth1.setMonth(currentMonth1.getMonth()+1);renderHolCalendars();renderCalendars();updateAll();});
document.querySelectorAll('#countToggle button').forEach(b=>b.addEventListener('click',()=>setLeaveCount(+b.dataset.count)));
document.querySelectorAll('.period-tab').forEach(t=>t.addEventListener('click',e=>{if(e.target.classList.contains('p-clear'))return;switchPeriod(+t.dataset.period);}));
$('p1Clear').addEventListener('click',e=>{e.stopPropagation();clearPeriod(1);});
$('p2Clear').addEventListener('click',e=>{e.stopPropagation();clearPeriod(2);});
document.querySelectorAll('#satMode input').forEach(r=>{r.addEventListener('change',()=>{
  document.querySelectorAll('#satMode label').forEach(l=>l.classList.toggle('active',l.querySelector('input').checked));
  const v=getSatMode();$('satHint').textContent=v==='all_off'?'完全週休2日制':v==='biweekly'?'隔週土曜休み（クリックで調整可）':'土曜出勤';
  $('satCustomArea').style.display=v==='biweekly'?'block':'none';
  customDayOff.clear();customDayOn.clear();
  renderHolCalendars();renderCalendars();updateAll();
});});
$('holidayOff').addEventListener('change',()=>{renderHolCalendars();renderCalendars();updateAll();});
['cutoffDay','healthRate','workInLeave1','workInLeave2','shienKyuhu'].forEach(id=>{$(id).addEventListener('input',()=>{autoCalcFromSalary();renderHolCalendars();updateAll();});$(id).addEventListener('change',()=>{autoCalcFromSalary();renderHolCalendars();updateAll();});});

// 初期化
autoCalcFromSalary();
renderHolCalendars();renderCalendars();updateAll();

/* ===== 印刷ボタン ===== */
$('wsResultPrintBtn').addEventListener('click', function() {
  const emp = ($('wsEmployeeName').value || '').trim();
  const co = ($('wsCompanyName').value || '').trim();
  const base = +$('baseSalary').value || 0;
  const m1 = currentMonth1, m2 = getMonth2();
  const tot = period1[1].length + period1[2].length + period2[1].length + period2[2].length;
  const fmtM = m => `${m.getFullYear()}年${m.getMonth()+1}月`;

  // 印刷用ヘッダーに値をセット
  $('wsPhEmployee').textContent = emp || '________________';
  $('wsPhCompany').textContent = co;
  $('wsPhMeta').textContent =
    `月給 ${base.toLocaleString()}円 ／ `
    + (tot > 0
        ? `育休期間：${fmtM(m1)}〜${fmtM(m2)}（計${tot}日）`
        : '育休期間：未選択');

  window.print();
});
})();
</script>
