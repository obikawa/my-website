---
import Layout from '../../layouts/Layout.astro';

// 無料でつかえる小さな専門家アプリ
const freeTools = [
  {
    href: '/minimum-wage',
    icon: '💰',
    color: 'primary',
    series: '最低賃金の小さな専門家',
    title: '最低賃金チェッカー',
    desc: '月給・日給・歩合給を時間額に換算し、都道府県の最低賃金をクリアしているか判定します。令和7年度の発効日付きデータに対応。',
    cta: 'チェックする →',
    ai: false,
  },
  {
    href: '/tools/papa-ikukyu/',
    icon: '👶',
    color: 'pink',
    series: 'パパ育休の小さな専門家',
    title: '産後パパ育休<br />社会保険料免除チェッカー',
    desc: 'カレンダーで育休期間を選ぶだけで、社会保険料が免除されるか自動判定。2ヶ月分の免除を狙う最適な取り方もわかります。',
    cta: 'チェックする →',
    ai: false,
  },
  {
    href: '/tools/wage-sim/',
    icon: '💴',
    color: 'purple',
    series: '育休手取りの小さな専門家',
    title: '産後パパ育休<br />賃金シミュレーター',
    desc: '育休期間を選ぶだけで、育児休業給付金・社会保険料免除を踏まえた2ヶ月分の手取りをシミュレーション。欠勤控除・給付金・源泉所得税まで一括計算。',
    cta: 'シミュレーションする →',
    ai: false,
  },
  {
    href: '/tools/yukyu-fuyo/',
    icon: '📅',
    color: 'primary',
    series: '有給の小さな専門家',
    title: '有給休暇<br />付与確認ツール',
    desc: '入社日と付与パターンを選ぶだけで、初回・2回目以降の有給付与日と日数を自動計算。8種類の付与ルールに対応し、印刷・PDF保存にも対応。',
    cta: '確認する →',
    ai: false,
  },
];

// 開発実績・導入支援（紹介のみ）
const showcaseTools = [
  {
    icon: '📄',
    color: 'amber',
    series: 'フリーランス法対応の小さな専門家',
    title: '発注書管理アプリ',
    desc: 'フリーランス法（特定受託事業者取引適正化法）に対応した発注書を作成・管理。記載事項の漏れを防ぎ、取引条件の明示をかんたんに整えます。',
    ai: false,
  },
  {
    icon: '🗂️',
    color: 'green',
    series: '電帳法対応の小さな専門家',
    title: 'ファイル名変換アプリ',
    desc: '電子帳簿保存法の要件に沿って、取引年月日・取引先・金額をルール化したファイル名へ一括変換。AIが書類を読み取り、検索性をらくらく確保します。',
    ai: true,
  },
];

const seriesColor = {
  primary: 'text-primary-600',
  pink: 'text-pink-600',
  purple: 'text-purple-600',
  amber: 'text-amber-600',
  green: 'text-green-700',
};
const iconBg = {
  primary: 'bg-primary-50',
  pink: 'bg-pink-50',
  purple: 'bg-purple-50',
  amber: 'bg-amber-50',
  green: 'bg-green-50',
};
const ctaColor = {
  primary: 'text-primary-700',
  pink: 'text-pink-600',
  purple: 'text-purple-600',
};
---

<Layout
  title="小さな専門家アプリ"
  description="おびかわ社労士事務所の「小さな専門家アプリ」。最低賃金の小さな専門家・パパ育休の小さな専門家・育休手取りの小さな専門家・有給の小さな専門家など、定型作業を任せて本業に専念できる無料ツールをご利用いただけます。"
>

  <section class="bg-gradient-to-br from-primary-800 to-primary-600 text-white py-16 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <p class="text-primary-200 text-sm font-medium tracking-widest uppercase mb-3">Small Specialist Apps</p>
      <h1 class="text-4xl font-bold">小さな専門家アプリ</h1>
      <p class="mt-4 text-primary-100 max-w-xl mx-auto">
        社労士が監修した、定型作業を任せて本業に専念するための専用ツール。<br />
        無料でつかえるアプリと、開発・導入支援の実績をご紹介します。
      </p>
    </div>
  </section>

  <!-- ===== 無料でつかえるアプリ ===== -->
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <div class="mb-8">
        <span class="inline-block text-xs font-bold text-primary-700 bg-primary-50 border border-primary-100 px-3 py-1 rounded-full mb-3">無料でつかえる</span>
        <h2 class="text-2xl font-bold text-gray-900">無料アプリ</h2>
        <p class="text-sm text-gray-600 mt-2">どなたでもその場でご利用いただけます。計算・判定はこれに任せて、本業に専念しましょう。</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {freeTools.map((t) => (
          <a href={t.href} class="group bg-white rounded-2xl p-8 border border-gray-100 shadow-sm hover:shadow-md transition-shadow flex flex-col">
            <div class="flex items-center justify-between mb-4">
              <div class={`w-12 h-12 ${iconBg[t.color]} rounded-xl flex items-center justify-center text-2xl`}>{t.icon}</div>
              {t.ai && (
                <span class="inline-flex items-center gap-1 text-[10px] font-bold text-white bg-gradient-to-r from-accent-500 to-accent-600 px-2.5 py-1 rounded-full tracking-wide">AI活用</span>
              )}
            </div>
            <p class={`text-xs font-semibold ${seriesColor[t.color]} mb-1`}>{t.series}</p>
            <h3 class="text-lg font-bold text-gray-900 mb-2" set:html={t.title} />
            <p class="text-sm text-gray-600 leading-relaxed flex-1">{t.desc}</p>
            <span class={`mt-5 ${ctaColor[t.color]} text-sm font-semibold group-hover:underline`}>{t.cta}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== 開発実績・導入支援 ===== -->
  <section class="py-16 px-4 bg-warm-50">
    <div class="max-w-3xl mx-auto">
      <div class="mb-8">
        <span class="inline-block text-xs font-bold text-teal-700 bg-teal-50 border border-teal-100 px-3 py-1 rounded-full mb-3">開発実績・導入支援</span>
        <h2 class="text-2xl font-bold text-gray-900">業務に合わせてつくるアプリ</h2>
        <p class="text-sm text-gray-600 mt-2">顧問契約のお客様向けに、業務に合わせた専用アプリを開発しています。導入をご希望の場合はお問い合わせください。</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {showcaseTools.map((t) => (
          <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm flex flex-col">
            <div class="flex items-center justify-between mb-4">
              <div class={`w-12 h-12 ${iconBg[t.color]} rounded-xl flex items-center justify-center text-2xl`}>{t.icon}</div>
              {t.ai && (
                <span class="inline-flex items-center gap-1 text-[10px] font-bold text-white bg-gradient-to-r from-accent-500 to-accent-600 px-2.5 py-1 rounded-full tracking-wide">AI活用</span>
              )}
            </div>
            <p class={`text-xs font-semibold ${seriesColor[t.color]} mb-1`}>{t.series}</p>
            <h3 class="text-lg font-bold text-gray-900 mb-2">{t.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed flex-1">{t.desc}</p>
            <span class="mt-5 inline-flex w-fit text-xs font-semibold text-gray-500 bg-gray-100 px-3 py-1 rounded-full">導入支援はお問い合わせください</span>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
