---
export interface Props {
  title: string;
  description?: string;
  fullTitle?: string;
  ogImage?: string;
}

const { title, description = '名古屋を中心に中小企業の働き方改革を支援する社労士事務所。男性育休の導入支援、就業規則の見直し、DX・AIによる業務改善まで一貫してサポートします。', fullTitle, ogImage = '/logo.png' } = Astro.props;
const pageTitle = fullTitle ?? `${title} | おびかわ社労士事務所`;
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const siteUrl = 'https://nagoyasakae.com';
const canonicalUrl = siteUrl + Astro.url.pathname;

// 事務所情報の構造化データ(全ページ共通)
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'おびかわ社労士事務所',
  url: siteUrl,
  logo: siteUrl + '/logo.png',
  image: siteUrl + '/logo.png',
  description: 'AIに仕事をさせて、本業に専念しよう。小さな専門家AIとアプリで、中小企業が本業に専念できる仕組みをつくる名古屋の社労士事務所。',
  founder: {
    '@type': 'Person',
    name: '大日川 聡一',
    jobTitle: '社会保険労務士',
  },
  address: {
    '@type': 'PostalAddress',
    postalCode: '460-0008',
    addressRegion: '愛知県',
    addressLocality: '名古屋市中区',
    streetAddress: '栄5-26-39 GS栄ビル3F',
    addressCountry: 'JP',
  },
  areaServed: '名古屋市を中心とした愛知県',
  knowsAbout: ['社会保険労務士業務', 'AIの社会実装', '小さな専門家', '男性育休', '働き方改革', '就業規則'],
};
const navLinks = [
  { href: '/',             label: 'トップ' },
  { href: '/shakai-jisso/', label: 'AI×人事' },
  { href: '/ai-expert/',   label: '小さな専門家' },
  { href: '/consulting/',  label: 'コンサルティング' },
  { href: '/seminar/',     label: 'セミナー' },
  { href: '/price',        label: '料金表' },
  { href: '/tools/',       label: 'ツール' },
  { href: '/contact',      label: 'お問い合わせ' },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- OGP -->
    <meta property="og:site_name" content="おびかわ社労士事務所" />
    <meta property="og:type" content={pathname === '/' ? 'website' : 'article'} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={siteUrl + ogImage} />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={siteUrl + ogImage} />

    <!-- 構造化データ(事務所情報) -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700&family=Shippori+Mincho+B1:wght@400;600;700;800&family=Zen+Kaku+Gothic+New:wght@900&display=swap" rel="stylesheet" />
    <title>{pageTitle}</title>
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-6HLXWWR9P4"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-6HLXWWR9P4');
    </script>
    <slot name="head" />
  </head>
  <body class="font-sans bg-warm-50 text-primary-900 antialiased">

    <!-- Navigation -->
    <nav class="sticky top-0 z-50 bg-primary-900/95 backdrop-blur-sm border-b border-primary-800">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center shrink-0">
            <img src="/logo.png" alt="おびかわ社労士事務所" class="h-8 md:h-6 lg:h-8 xl:h-10 w-auto object-contain" />
          </a>
          <!-- Desktop menu (md以上で表示。中間幅はロゴ・文字を縮小して全項目を収める) -->
          <div class="hidden md:flex items-center gap-0.5">
            {navLinks.map(({ href, label }) => {
              const isActive = href === '/' ? pathname === '/' : pathname.startsWith(href);
              const isContact = href === '/contact';
              const isHome = href === '/';
              return (
                <a
                  href={href}
                  class={isContact
                    ? `ml-1 lg:ml-2 px-2 lg:px-3 xl:px-3.5 py-1.5 text-xs lg:text-sm font-medium border whitespace-nowrap transition-all duration-200 ${
                        isActive
                          ? 'bg-accent-500 text-white border-accent-500'
                          : 'text-accent-600 border-accent-500 hover:bg-accent-500 hover:text-white'
                      }`
                    : `relative px-1 lg:px-2 xl:px-2.5 py-2 text-xs lg:text-sm font-medium whitespace-nowrap transition-colors duration-200 ${
                        isHome ? 'hidden lg:block' : ''
                      } ${
                        isActive
                          ? 'text-white'
                          : 'text-primary-200 hover:text-white'
                      }`
                  }
                >
                  {label}
                  {!isContact && isActive && (
                    <span class="absolute bottom-0 left-1 right-1 lg:left-2 lg:right-2 h-0.5 bg-accent-500"></span>
                  )}
                </a>
              );
            })}
          </div>

          <!-- Mobile hamburger button -->
          <button
            id="navToggle"
            type="button"
            aria-label="メニューを開く"
            aria-expanded="false"
            aria-controls="mobileMenu"
            class="md:hidden inline-flex items-center justify-center w-10 h-10 text-primary-200 hover:text-white"
          >
            <svg id="navIconOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="navIconClose" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu panel -->
      <div id="mobileMenu" class="hidden md:hidden border-t border-primary-800 bg-primary-900">
        <div class="px-4 py-3 space-y-1">
          {navLinks.map(({ href, label }) => {
            const isActive = href === '/' ? pathname === '/' : pathname.startsWith(href);
            const isContact = href === '/contact';
            return (
              <a
                href={href}
                class={isContact
                  ? `block px-4 py-3 text-base font-semibold text-center border transition-colors duration-200 ${
                      isActive
                        ? 'bg-accent-500 text-white border-accent-500'
                        : 'text-accent-600 border-accent-500'
                    }`
                  : `block px-4 py-3 text-base font-medium border-l-2 transition-colors duration-200 ${
                      isActive
                        ? 'text-white border-accent-500 bg-primary-800'
                        : 'text-primary-200 border-transparent'
                    }`
                }
              >
                {label}
              </a>
            );
          })}
        </div>
      </div>
    </nav>

    <script is:inline>
      (function () {
        const toggle = document.getElementById('navToggle');
        const menu = document.getElementById('mobileMenu');
        const iconOpen = document.getElementById('navIconOpen');
        const iconClose = document.getElementById('navIconClose');
        if (!toggle || !menu) return;
        toggle.addEventListener('click', function () {
          const willOpen = menu.classList.contains('hidden');
          menu.classList.toggle('hidden');
          iconOpen.classList.toggle('hidden', willOpen);
          iconClose.classList.toggle('hidden', !willOpen);
          toggle.setAttribute('aria-expanded', String(willOpen));
          toggle.setAttribute('aria-label', willOpen ? 'メニューを閉じる' : 'メニューを開く');
        });
      })();
    </script>

    <!-- Main content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-primary-900 text-primary-300 mt-20">
      <div class="h-0.5 bg-accent-500"></div>
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-10">
          <div>
            <p class="font-display text-xl font-bold text-white mb-0.5">おびかわ</p>
            <p class="text-accent-400 text-xs font-semibold tracking-[0.2em] mb-5">社労士事務所</p>
            <p class="text-base leading-relaxed">本業は、人間が。あとは、AIに任せる。小さな専門家AIとアプリで、中小企業が本業に専念できる仕組みをつくる名古屋の社労士事務所です。</p>
          </div>
          <div>
            <h4 class="text-accent-400 text-xs font-semibold tracking-[0.2em] uppercase mb-5">Pages</h4>
            <ul class="space-y-3 text-base">
              <li><a href="/" class="hover:text-white transition-colors">トップページ</a></li>
              <li><a href="/shakai-jisso/" class="hover:text-white transition-colors">AI×人事（AIの社会実装）</a></li>
              <li><a href="/ai-expert/" class="hover:text-white transition-colors">小さな専門家</a></li>
              <li><a href="/consulting/" class="hover:text-white transition-colors">コンサルティング</a></li>
              <li><a href="/seminar/" class="hover:text-white transition-colors">セミナー・研修</a></li>
              <li><a href="/price" class="hover:text-white transition-colors">料金表</a></li>
              <li><a href="/contact" class="hover:text-white transition-colors">お問い合わせ</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-accent-400 text-xs font-semibold tracking-[0.2em] uppercase mb-5">Tools</h4>
            <ul class="space-y-3 text-base">
              <li><a href="/minimum-wage" class="hover:text-white transition-colors">最低賃金チェック</a></li>
              <li><a href="/tools/papa-ikukyu/" class="hover:text-white transition-colors">産後パパ育休社会保険チェッカー</a></li>
              <li><a href="/tools/wage-sim/" class="hover:text-white transition-colors">産後パパ育休 賃金シミュレーター</a></li>
              <li><a href="/tools/yukyu-fuyo/" class="hover:text-white transition-colors">有給休暇付与確認ツール</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-accent-400 text-xs font-semibold tracking-[0.2em] uppercase mb-5">Location</h4>
            <address class="not-italic text-base space-y-2">
              <p>〒460-0008</p>
              <p>愛知県名古屋市中区栄5-26-39</p>
              <p>GS栄ビル3F</p>
            </address>
          </div>
        </div>
        <div class="border-t border-primary-800 mt-12 pt-6 text-center text-xs text-primary-600 space-y-1.5">
          <p>※「小さな専門家」は商標出願中です</p>
          <p>&copy; {new Date().getFullYear()} おびかわ社労士事務所. All rights reserved.</p>
        </div>
      </div>
    </footer>

  </body>
</html>

<style is:global>
  /* Hero entrance animations */
  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes heroFadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50%       { opacity: 1;   transform: scaleY(1.3); }
  }

  .hero-line-1 { animation: heroFadeUp 0.75s cubic-bezier(.22,1,.36,1) 0.15s both; }
  .hero-line-2 { animation: heroFadeUp 0.75s cubic-bezier(.22,1,.36,1) 0.35s both; }
  .hero-line-3 { animation: heroFadeUp 0.75s cubic-bezier(.22,1,.36,1) 0.55s both; }
  .hero-line-4 { animation: heroFadeUp 0.75s cubic-bezier(.22,1,.36,1) 0.75s both; }
  .hero-fade   { animation: heroFadeIn 1.2s ease 0.1s both; }
  .scroll-bar  { animation: scrollPulse 2s ease-in-out infinite; }
</style>
